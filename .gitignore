# ---- Terraform ----
# Local .terraform working directories
**/.terraform/*

# State files: hold account ARNs, resource IDs, and sometimes secrets in plaintext
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Variable files: likely to contain sensitive values
*.tfvars
*.tfvars.json

# Plan output (can embed sensitive values)
*tfplan*

# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# ---- Credentials / secrets ----
.env
.env.*
*.pem
*.key
credentials
aws-credentials*

# ---- OS / editor cruft ----
.DS_Store